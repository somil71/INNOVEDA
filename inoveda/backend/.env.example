APP_NAME=INOVEDA API
APP_VERSION=0.2.0
ENVIRONMENT=development
DATABASE_URL=sqlite:///./inoveda.db
JWT_SECRET=replace_me_for_any_shared_env
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
USE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
RATE_LIMIT_PER_MINUTE=120
OUTBREAK_METHOD=zscore
OUTBREAK_WEEKS_HISTORY=4
OUTBREAK_Z_THRESHOLD=2.0
OUTBREAK_P_THRESHOLD=0.05
OUTBREAK_MIN_CASES=3
MODEL_PATH=ml/triage_model.joblib
